@model Auction_web.Models.ChangePasswordViewModel

<div style="background: #0D0C14; padding: 40px 20px; color: #fff; display: flex; justify-content: center; align-items: flex-start;">

    <div style="background: #181622; border-radius: 16px; padding: 30px; border: 1px solid rgba(255,255,255,0.03); width: 100%; max-width: 400px; box-shadow: 0 10px 25px rgba(0,0,0,0.3);">

        <div style="text-align: center; margin-bottom: 20px;">
            <h2 style="margin: 0; color: #fff; font-size: 1.5rem;">Change Password</h2>
        </div>

        <form asp-action="ChangePassword" method="post">
            <div style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; color: #b2bec3; font-size: 0.8rem;">Current Password</label>
                <input asp-for="CurrentPassword" type="password" style="width: 100%; padding: 10px; background: #0D0C14; border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; color: white;" />
            </div>

            <div style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; color: #b2bec3; font-size: 0.8rem;">New Password</label>
                <input asp-for="NewPassword" type="password" style="width: 100%; padding: 10px; background: #0D0C14; border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; color: white;" />
            </div>

            <div style="margin-bottom: 25px;">
                <label style="display: block; margin-bottom: 5px; color: #b2bec3; font-size: 0.8rem;">Confirm New Password</label>
                <input asp-for="ConfirmNewPassword" type="password" style="width: 100%; padding: 10px; background: #0D0C14; border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; color: white;" />
            </div>

            <div style="display: flex; gap: 10px;">
                <button type="submit" style="flex: 1; background: #f1c40f; color: #12101A; font-weight: 600; border: none; padding: 10px; border-radius: 6px; cursor: pointer;">
                    Update
                </button>
                <a href="@Url.Action("Index", "Profile")" style="flex: 1; background: rgba(255,255,255,0.05); color: #fff; text-decoration: none; text-align: center; padding: 10px; border-radius: 6px; font-weight: 500; border: 1px solid rgba(255,255,255,0.08);">
                    Back
                </a>
            </div>
        </form>
    </div>
</div>
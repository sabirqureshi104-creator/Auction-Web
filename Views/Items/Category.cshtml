@model IEnumerable<Auction_web.Models.Item>
@{
    ViewData["Title"] = "Category: " + ViewBag.CategoryName;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div style="background: #0D0C14; padding: 2.5rem 6rem 3rem 6rem; color: #fff; font-family: 'Segoe UI', Roboto, sans-serif;">

    <!-- CATEGORY HEADER -->
    <div style="margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(255,255,255,0.05);">
        <h2 style="color: #fff; font-weight: 700; font-size: 2rem; margin: 0 0 0.5rem 0; display: flex; align-items: center; gap: 0.75rem;">
            <i class="fas fa-folder-open" style="color: #f1c40f;"></i> @ViewBag.CategoryName
        </h2>
        <p style="color: #818395; font-size: 0.95rem; margin: 0;">
            Browse items in this category
        </p>
    </div>

    @if (!Model.Any())
    {
        <div style="background: #181622; border-radius: 12px; border: 1px dashed rgba(255,255,255,0.05); padding: 4rem 2rem; margin-top: 2rem; text-align: center;">
            <i class="fas fa-box-open" style="font-size: 3rem; color: #636e72; margin-bottom: 1rem; display: block;"></i>
            <h4 style="color: #dfe6e9; font-weight: 500; font-size: 1.25rem; margin: 0 0 0.5rem 0;">No items in this category yet!</h4>
            <p style="color: #636e72; font-size: 0.88rem; max-width: 400px; margin: 0 auto 1.5rem auto;">Start selling or check back later for new listings.</p>
            <a href="@Url.Action("Create", "Items")" style="background: #2ecc71; color: #12101A; font-weight: 700; font-size: 0.85rem; padding: 0.6rem 1.25rem; border-radius: 6px; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem;">
                <i class="fas fa-plus"></i> Sell Something
            </a>
        </div>
    }
    else
    {
        <!-- CARDS GRID -->
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.5rem;">
            @foreach (var item in Model)
            {
                <div style="background: #181622; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.02); box-shadow: 0 10px 25px rgba(0,0,0,0.4); display: flex; flex-direction: column; height: 100%; transition: transform 0.2s, border-color 0.2s; hover:border-color #f1c40f; hover:transform translateY(-5px);">

                    <!-- IMAGE SECTION -->
                    <div style="position: relative; height: 180px; background: #13111C; overflow: hidden; display: flex; align-items: center; justify-content: center;">
                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <img src="/@item.ImagePath"
                                 style="width: 100%; height: 100%; object-fit: cover;"
                                 alt="@item.ItemTitle">
                        }
                        else
                        {
                            <div style="width: 100%; height: 100%; background: #0a0a14; display: flex; align-items: center; justify-content: center; color: #666;">
                                No Image
                            </div>
                        }

                        <!-- LIVE BADGE -->
                        <span style="position: absolute; top: 0.75rem; right: 0.75rem; background: rgba(46, 204, 113, 0.15); color: #2ecc71; border: 1px solid rgba(46, 204, 113, 0.2); font-size: 0.65rem; font-weight: 700; padding: 0.25rem 0.6rem; border-radius: 4px; text-transform: uppercase; display: inline-flex; align-items: center; gap: 0.25rem;">
                            <span style="width: 5px; height: 5px; background: #2ecc71; border-radius: 50%;"></span> Live
                        </span>
                    </div>

                    <!-- CONTENT SECTION -->
                    <div style="padding: 1rem; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between;">

                        <!-- TITLE & DESC -->
                        <div>
                            <h5 style="font-size: 0.95rem; font-weight: 600; color: #fff; margin: 0 0 0.4rem 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@item.ItemTitle">
                                @item.ItemTitle
                            </h5>
                            <p style="color: #818395; font-size: 0.8rem; line-height: 1.4; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @item.ItemDescription
                            </p>
                        </div>

                        <!-- PRICE & BUTTON -->
                        <div style="margin-top: 0.75rem; border-top: 1px solid rgba(255,255,255,0.03); padding-top: 0.75rem;">
                            <div style="color: #636e72; font-size: 0.7rem; text-transform: uppercase; font-weight: 700; margin-bottom: 0.3rem;">Current Bid</div>
                            <div style="display: flex; justify-content: space-between; align-items: center;">
                                <span style="color: #f1c40f; font-size: 1.1rem; font-weight: 700;">
                                    $@String.Format("{0:N2}", item.CurrentBid ?? item.MinimumBid)
                                </span>
                                <a href="@Url.Action("Details", "Items", new { id = item.ItemId })"
                                   style="background: #2ecc71; color: #12101A; border: none; padding: 0.4rem 0.8rem; font-weight: 700; font-size: 0.75rem; border-radius: 4px; text-decoration: none; display: inline-flex; align-items: center; gap: 0.3rem; cursor: pointer;">
                                    View <i class="fas fa-arrow-right" style="font-size: 0.65rem;"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                </div>
            }
        </div>
    }
</div>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AuctionHub Admin</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>

<body>

    <div class="admin-wrapper">

        <aside class="sidebar">

            <div class="logo">
                <i class="fas fa-gavel"></i>
                <span>AuctionHub</span>
            </div>

            <ul>

                <li>
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <i class="fas fa-chart-line"></i>
                        Dashboard
                    </a>
                </li>

                <li>
                    <a asp-area="Admin" asp-controller="Users" asp-action="Index">
                        <i class="fas fa-users"></i>
                        Users
                    </a>
                </li>

                <li>
                    <a asp-area="Admin" asp-controller="Categories" asp-action="Index">
                        <i class="fas fa-layer-group"></i>
                        Categories
                    </a>
                </li>

                <li>
                    <a asp-area="Admin" asp-controller="Items" asp-action="Index">
                        <i class="fas fa-gavel"></i>
                        Auctions
                    </a>
                </li>

                <li>
                    <a asp-area="Admin" asp-controller="Bids" asp-action="Index">
                        <i class="fas fa-hand-holding-dollar"></i>
                        Bids
                    </a>
                </li>

                <li>
                    <a asp-area="Admin" asp-controller="Reports" asp-action="Index">
                        <i class="fas fa-chart-pie"></i>
                        Reports
                    </a>
                </li>

                <li>
                    <a asp-area="Admin" asp-controller="Settings" asp-action="Index">
                        <i class="fas fa-cog"></i>
                        Settings
                    </a>
                </li>

            </ul>

        </aside>

        <main>

            <header class="topbar">

                <div>
                    <h2>@ViewData["Title"]</h2>
                </div>

                <div>

                    <form asp-controller="Account"
                          asp-action="Logout"
                          asp-area=""
                          method="post">

                        @Html.AntiForgeryToken()

                        <button class="logout-btn">
                            <i class="fas fa-sign-out-alt"></i>
                            Logout
                        </button>

                    </form>

                </div>

            </header>

            <section class="content">

                @RenderBody()

            </section>

        </main>

    </div>

</body>
</html>